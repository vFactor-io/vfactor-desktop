{
  "name": "nucleus-desktop",
  "version": "0.1.1",
  "description": "Desktop AI agent app",
  "type": "module",
  "main": "out/main/main.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "build": "electron-vite build",
    "dist": "bun run build && electron-builder",
    "release": "bun run build && electron-builder --publish onTag",
    "cli": "bun run index.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^37.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "typescript": "^5",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@headless-tree/core": "^1.6.2",
    "@headless-tree/react": "^1.6.2",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.4",
    "@lexical/react": "^0.41.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-symbols/icons": "^1.3.1",
    "@tailwindcss/vite": "^4.1.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.23",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.35.0",
    "lexical": "^0.41.0",
    "nanoid": "^5.1.6",
    "node-pty": "^1.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shadcn": "^3.6.3",
    "streamdown": "^1.6.11",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.1",
    "zustand": "^5.0.9"
  },
  "build": {
    "appId": "io.nucleus.desktop",
    "productName": "Nucleus",
    "files": [
      "out/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github"
      }
    ],
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": ["nsis"],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
