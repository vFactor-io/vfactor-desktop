{
  "name": "nucleus",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run desktop:dev",
    "build": "bun run desktop:build && bun run site:build",
    "preview": "bun run desktop:preview",
    "typecheck": "bun run desktop:typecheck",
    "desktop:dev": "bun run --cwd apps/desktop dev",
    "desktop:preview": "bun run --cwd apps/desktop preview",
    "desktop:build": "bun run --cwd apps/desktop build",
    "desktop:dist": "bun run --cwd apps/desktop dist",
    "desktop:release": "bun run --cwd apps/desktop release",
    "desktop:cli": "bun run --cwd apps/desktop cli",
    "desktop:typecheck": "bun run --cwd apps/desktop typecheck",
    "site:dev": "bun run --cwd apps/site dev",
    "site:build": "bun run --cwd apps/site build",
    "site:preview": "bun run --cwd apps/site preview"
  }
}
