---
import BaseLayout from "../layouts/BaseLayout.astro"

const GITHUB_REPO_URL = "https://github.com/vFactor-io/vfactor-desktop"
const LATEST_RELEASE_URL = `${GITHUB_REPO_URL}/releases/latest`
const LATEST_RELEASE_API_URL =
  "https://api.github.com/repos/vFactor-io/vfactor-desktop/releases/latest"
---

<BaseLayout>
  {/* ── Navigation ── */}
  <nav class="nav">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 56px;">
      <a href="#" class="font-display" style="font-size: 1.1rem; color: var(--text); text-decoration: none; letter-spacing: 0.02em;">
        VFACTOR
      </a>
      <div style="display: flex; align-items: center; gap: 32px;">
        <a href="#features" class="nav-link hidden-sm">Features</a>
        <a href="#harnesses" class="nav-link hidden-sm">Harnesses</a>
        <a href={GITHUB_REPO_URL} class="nav-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
      </div>
    </div>
  </nav>

  {/* ── Hero ── */}
  <section class="grid-bg" style="position: relative; overflow: hidden;">
    <div class="container" style="padding-top: clamp(80px, 14vh, 160px); padding-bottom: clamp(60px, 10vh, 120px); text-align: center; position: relative; z-index: 1;">
      <div style="opacity: 0; animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;">
        <div class="section-label" style="margin-bottom: 24px;">Open Source &middot; Desktop &middot; Local First</div>
        <h1 class="font-display" style="font-size: clamp(3rem, 10vw, 7.5rem); line-height: 0.95; letter-spacing: -0.02em; color: var(--text);">
          VFACTOR
        </h1>
        <p class="font-body" style="margin-top: 28px; font-size: clamp(1.1rem, 2vw, 1.4rem); font-weight: 400; color: var(--text-muted); max-width: 560px; margin-left: auto; margin-right: auto; font-style: italic;">
          The desktop environment for agentic software development. Bring your own models. Own your code.
        </p>

        <div style="margin-top: 40px; display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <a href={LATEST_RELEASE_URL} class="btn btn-primary" id="download-btn" data-download-primary>
            <span id="download-icon"></span>
            <span id="download-label">Download</span>
          </a>
          <a href={GITHUB_REPO_URL} target="_blank" rel="noopener" class="btn btn-ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>

      {/* Screenshot */}
      <div style="margin-top: clamp(48px, 8vh, 80px); position: relative; opacity: 0; animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;">
        <div class="screenshot-glow"></div>
        <div class="screenshot-container">
          <img
            src="/app-screenshot.png"
            alt="vFactor — Multi-agent workspace with chat, file browser, terminal, and built-in browser"
            style="display: block; width: 100%; height: auto;"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  {/* ── Download ── */}
  <section id="download" class="section">
    <div class="container">
      <div class="reveal" style="text-align: center; margin-bottom: 48px;">
        <div class="section-label">Download</div>
        <h2 class="font-display" style="font-size: clamp(1.8rem, 4vw, 2.8rem); line-height: 1.1; margin-bottom: 16px;">
          GET VFACTOR<br />DESKTOP
        </h2>
        <p class="font-body" style="color: var(--text-muted); max-width: 500px; margin: 0 auto; font-style: italic;">
          Install the latest signed release for your machine.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">
        <a href={LATEST_RELEASE_URL} class="feature-card reveal reveal-delay-1 download-card" data-download-card data-platform="mac-arm64" target="_blank" rel="noopener">
          <div class="feature-icon" data-download-card-icon></div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">MAC APPLE SILICON</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            For M-series Macs. Downloads the latest arm64 DMG.
          </p>
        </a>

        <a href={LATEST_RELEASE_URL} class="feature-card reveal reveal-delay-2 download-card" data-download-card data-platform="mac-x64" target="_blank" rel="noopener">
          <div class="feature-icon" data-download-card-icon></div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">MAC INTEL</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            For Intel Macs. Downloads the latest x64 DMG.
          </p>
        </a>

        <a href={LATEST_RELEASE_URL} class="feature-card reveal reveal-delay-3 download-card" data-download-card data-platform="windows-x64" target="_blank" rel="noopener">
          <div class="feature-icon" data-download-card-icon></div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">WINDOWS</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            For Windows PCs. Downloads the latest x64 installer.
          </p>
        </a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  {/* ── Harnesses ── */}
  <section id="harnesses" class="section">
    <div class="container">
      <div class="reveal">
        <div class="section-label">Integrations</div>
        <h2 class="font-display" style="font-size: clamp(1.8rem, 4vw, 2.8rem); line-height: 1.1; margin-bottom: 16px;">
          CHOOSE YOUR<br />CO-PILOT
        </h2>
        <p class="font-body" style="color: var(--text-muted); max-width: 480px; font-style: italic;">
          vFactor adapts to the runtime you prefer. Switch between models without leaving your workspace.
        </p>
      </div>

      <div style="margin-top: 56px; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
        {/* Codex */}
        <div class="harness-card reveal reveal-delay-1">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
            <div style="display: flex; align-items: center; gap: 12px;">
              <div style="width: 40px; height: 40px; border: 1px solid var(--border); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; background: rgba(25, 195, 125, 0.08);">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#19c37d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                  <path d="M2 17l10 5 10-5"/>
                  <path d="M2 12l10 5 10-5"/>
                </svg>
              </div>
              <span class="font-mono" style="font-size: 1rem; font-weight: 700;">Codex</span>
            </div>
            <span class="badge badge-experimental">Experimental</span>
          </div>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            OpenAI's Codex App Server harness. Deep reasoning, code generation, and multi-file editing powered by GPT-4o and o3.
          </p>
          <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); display: flex; gap: 16px; flex-wrap: wrap;">
            <span class="font-mono" style="font-size: 0.7rem; color: var(--text-dim);">JSON-RPC</span>
            <span class="font-mono" style="font-size: 0.7rem; color: var(--text-dim);">Streaming</span>
            <span class="font-mono" style="font-size: 0.7rem; color: var(--text-dim);">Tool Calls</span>
          </div>
        </div>

        {/* Claude Code */}
        <div class="harness-card reveal reveal-delay-2">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
            <div style="display: flex; align-items: center; gap: 12px;">
              <div style="width: 40px; height: 40px; border: 1px solid var(--border); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; background: rgba(207, 100, 60, 0.08);">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#cf643c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
              </div>
              <span class="font-mono" style="font-size: 1rem; font-weight: 700;">Claude Code</span>
            </div>
            <span class="badge badge-experimental">Experimental</span>
          </div>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            Anthropic's Claude Code CLI harness. Thoughtful analysis, debugging, and architecture decisions powered by Claude 3.7 Sonnet.
          </p>
          <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); display: flex; gap: 16px; flex-wrap: wrap;">
            <span class="font-mono" style="font-size: 0.7rem; color: var(--text-dim);">Agent Loop</span>
            <span class="font-mono" style="font-size: 0.7rem; color: var(--text-dim);">Permissions</span>
            <span class="font-mono" style="font-size: 0.7rem; color: var(--text-dim);">Subagents</span>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-3" style="margin-top: 32px; text-align: center;">
        <p class="font-mono" style="font-size: 0.75rem; color: var(--text-dim);">
          More harnesses coming. OpenCode, local LLMs, and custom adapters.
        </p>
      </div>
    </div>
  </section>

  <hr class="divider" />

  {/* ── Features ── */}
  <section id="features" class="section">
    <div class="container">
      <div class="reveal" style="text-align: center; margin-bottom: 64px;">
        <div class="section-label">Capabilities</div>
        <h2 class="font-display" style="font-size: clamp(1.8rem, 4vw, 2.8rem); line-height: 1.1; margin-bottom: 16px;">
          BUILT FOR<br />OUTCOMES
        </h2>
        <p class="font-body" style="color: var(--text-muted); max-width: 500px; margin: 0 auto; font-style: italic;">
          Not just chat. A complete environment for building software with agents.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
        {/* Feature 1 */}
        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">BUILT-IN BROWSER</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            Test, preview, and iterate without leaving the app. Your agent can browse, screenshot, and interact with live pages.
          </p>
        </div>

        {/* Feature 2 */}
        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">ONE-CLICK PR</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            When your agent finishes, review the diff and open a pull request in seconds. Ship without switching to your terminal.
          </p>
        </div>

        {/* Feature 3 */}
        <div class="feature-card reveal reveal-delay-3">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">PROJECT SCOPED</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            Every folder is a workspace. Chats, files, and terminal sessions are scoped to the project you have open. Context stays where it belongs.
          </p>
        </div>

        {/* Feature 4 */}
        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">SUPERVISED WORKFLOWS</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            See plans before execution. Approve file changes, commands, and destructive actions. Stay in control while the agent does the work.
          </p>
        </div>

        {/* Feature 5 */}
        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/>
              <rect x="2" y="14" width="20" height="8" rx="2" ry="2"/>
              <line x1="6" y1="6" x2="6.01" y2="6"/>
              <line x1="6" y1="18" x2="6.01" y2="18"/>
            </svg>
          </div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">MULTI-AGENT</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            Run different models side by side. Compare approaches, delegate sub-tasks, and let specialists handle what they do best.
          </p>
        </div>

        {/* Feature 6 */}
        <div class="feature-card reveal reveal-delay-3">
          <div class="feature-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </div>
          <h3 class="font-mono" style="font-size: 0.9rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em;">LOCAL FIRST</h3>
          <p class="font-body" style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            Your code never leaves your machine unless you choose. Data, context, and history stay local. Fully portable and self-managed.
          </p>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  {/* ── Terminal Demo ── */}
  <section class="section" style="position: relative; overflow: hidden;">
    <div class="container" style="position: relative; z-index: 1;">
      <div class="reveal" style="text-align: center; margin-bottom: 56px;">
        <div class="section-label">Workflow</div>
        <h2 class="font-display" style="font-size: clamp(1.8rem, 4vw, 2.8rem); line-height: 1.1; margin-bottom: 16px;">
          FROM IDEA TO<br />PULL REQUEST
        </h2>
        <p class="font-body" style="color: var(--text-muted); max-width: 480px; margin: 0 auto; font-style: italic;">
          Describe what you want. Watch the agent plan, execute, and ship. You supervise every step.
        </p>
      </div>

      <div class="reveal reveal-delay-1" style="max-width: 720px; margin: 0 auto;">
        <div class="terminal">
          <div class="terminal-header">
            <div class="terminal-dot red"></div>
            <div class="terminal-dot yellow"></div>
            <div class="terminal-dot green"></div>
            <span class="font-mono" style="font-size: 0.7rem; color: var(--text-dim); margin-left: 8px;">vfactor — zsh</span>
          </div>
          <div class="terminal-body">
            <div class="terminal-line">
              <span class="prompt">$</span> <span class="command">vfactor init landing-page</span>
            </div>
            <div class="terminal-line">
              <span class="success">✓</span> <span class="output">Project initialized in ./landing-page</span>
            </div>
            <div class="terminal-line" style="margin-top: 8px;">
              <span class="prompt">$</span> <span class="command">vfactor chat "Build a responsive landing page with a hero, features grid, and CTA"</span>
            </div>
            <div class="terminal-line">
              <span class="output">→ Using harness: codex</span>
            </div>
            <div class="terminal-line">
              <span class="output">→ Analyzing requirements...</span>
            </div>
            <div class="terminal-line">
              <span class="output">→ Planning file structure</span>
            </div>
            <div class="terminal-line" style="margin-top: 8px;">
              <span class="output">  [1/4] Creating index.html</span>
            </div>
            <div class="terminal-line">
              <span class="output">  [2/4] Writing styles.css</span>
            </div>
            <div class="terminal-line">
              <span class="output">  [3/4] Adding responsive breakpoints</span>
            </div>
            <div class="terminal-line">
              <span class="output">  [4/4] Implementing scroll animations</span>
            </div>
            <div class="terminal-line" style="margin-top: 8px;">
              <span class="success">✓</span> <span class="output">Changes complete. 4 files modified.</span>
            </div>
            <div class="terminal-line">
              <span class="prompt">$</span> <span class="command">vfactor pr --title "Add landing page"</span>
            </div>
            <div class="terminal-line">
              <span class="success">✓</span> <span class="output">Pull request opened: #42</span>
            </div>
            <div class="terminal-line" style="margin-top: 12px;">
              <span class="cursor"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  {/* ── Open Source ── */}
  <section class="section grid-bg" style="position: relative;">
    <div class="container" style="text-align: center; position: relative; z-index: 1;">
      <div class="reveal">
        <div class="section-label">Community</div>
        <h2 class="font-display" style="font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.1; margin-bottom: 20px;">
          BUILT IN THE OPEN
        </h2>
        <p class="font-body" style="color: var(--text-muted); max-width: 520px; margin: 0 auto 40px; font-style: italic;">
          vFactor is open source and community-driven. No black boxes, no vendor lock-in. Inspect the code, contribute, or fork it for your own needs.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <a href={GITHUB_REPO_URL} target="_blank" rel="noopener" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
            Star on GitHub
          </a>
          <a href={LATEST_RELEASE_URL} class="btn btn-ghost" data-download-primary>
            Download vFactor
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <footer class="footer">
    <div class="container" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
      <span class="font-display" style="font-size: 0.9rem; color: var(--text-dim);">VFACTOR</span>
      <div style="display: flex; gap: 24px;">
        <a href={GITHUB_REPO_URL} class="link-effect font-mono" style="font-size: 0.75rem; color: var(--text-muted);" target="_blank" rel="noopener">GitHub</a>
        <a href="#" class="link-effect font-mono" style="font-size: 0.75rem; color: var(--text-muted);">Documentation</a>
        <a href="#" class="link-effect font-mono" style="font-size: 0.75rem; color: var(--text-muted);">Discord</a>
      </div>
      <span class="font-mono" style="font-size: 0.7rem; color: var(--text-dim);">MIT License &middot; 2025</span>
    </div>
  </footer>

  {/* ── Scripts ── */}
  <script>
    // Download button platform detection
    const icon = document.getElementById('download-icon')!
    const label = document.getElementById('download-label')!
    const primaryDownloadLinks = document.querySelectorAll<HTMLAnchorElement>('[data-download-primary]')
    const downloadCards = document.querySelectorAll<HTMLAnchorElement>('[data-download-card]')
    const ua = navigator.userAgent

    const apple = `<svg width="16" height="20" viewBox="0 0 170 170" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M150.37 130.25c-2.45 5.66-5.35 10.87-8.71 15.66-4.58 6.53-8.33 11.05-11.22 13.56-4.48 4.12-9.28 6.23-14.42 6.35-3.69 0-8.14-1.05-13.32-3.18-5.2-2.12-9.97-3.17-14.34-3.17-4.58 0-9.49 1.05-14.75 3.17-5.28 2.13-9.54 3.24-12.8 3.35-4.93.21-9.84-1.96-14.75-6.52-3.13-2.73-7.04-7.41-11.75-14.04-5.03-7.08-9.17-15.29-12.41-24.65-3.47-10.2-5.21-20.07-5.21-29.61 0-10.95 2.36-20.38 7.09-28.28 3.72-6.33 8.67-11.33 14.86-14.99 6.19-3.66 12.88-5.53 20.08-5.64 3.92 0 9.06 1.21 15.43 3.59 6.35 2.39 10.43 3.61 12.22 3.61 1.34 0 5.87-1.43 13.56-4.27 7.27-2.64 13.41-3.73 18.44-3.29 13.63 1.1 23.87 6.47 30.68 16.15-12.19 7.39-18.22 17.73-18.1 31 .12 10.33 3.86 18.93 11.2 25.77 3.33 3.17 7.05 5.61 11.19 7.35-.9 2.61-1.85 5.11-2.86 7.51zM119.11 7.24c0 8.1-2.96 15.66-8.86 22.67-7.12 8.32-15.73 13.13-25.07 12.37a25.2 25.2 0 0 1-.19-3.07c0-7.78 3.38-16.1 9.39-22.89 3-3.44 6.82-6.31 11.45-8.6 4.62-2.26 8.99-3.51 13.1-3.72.12 1.1.18 2.2.18 3.24z"/></svg>`
    const windows = `<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M6.555 1.375 0 2.237v5.45h6.555zM0 8.313v5.45l6.555.862V8.313zm7.278-7.06L16 0v7.687H7.278zM16 8.313v7.687l-8.722-1.252V8.313z"/></svg>`
    const linux = `<svg width="16" height="18" viewBox="0 0 448 512" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M236.9 .2c-40 0-77.9 16.5-97.1 53.3C121.5 87.2 116 133.5 120.4 175c-25.8 31.4-45.2 67.2-55.6 105.7-6.3 23.2-9.7 47.3-4.1 70.8 5.5 23.1 20.2 43.3 44.1 54.5l2.9 1.4c-3.2 10.3-3.4 21.5-.2 32.1 5.1 17 18 30 34.6 35.2 16.5 5.1 34.3 1.7 48.1-8.9l.5-.4.4.5c13.9 10.6 31.7 14 48.1 8.9 16.5-5.2 29.5-18.2 34.6-35.2 3.2-10.6 3-21.8-.2-32.1l2.9-1.4c23.8-11.3 38.6-31.5 44.1-54.5 5.6-23.5 2.2-47.6-4.1-70.8-10.4-38.6-29.8-74.3-55.6-105.7 4.4-41.5-1.1-87.8-19.4-121.5C222.6 16.7 276.9.2 236.9.2zm0 32c14 0 38.9 9.3 53.9 39.9 12.5 25.5 17.8 59 16 93.7-5.6-5.9-11.5-11.5-17.8-16.8 1.8-22.8-.2-46.5-8.7-66.1-4.7-10.8-15.7-16.2-26.7-16.2h-33.5c-11 0-22 5.4-26.7 16.2-8.5 19.6-10.5 43.3-8.7 66.1-6.2 5.3-12.2 10.9-17.8 16.8-1.8-34.7 3.5-68.2 16-93.7 15-30.6 39.9-39.9 53.9-39.9z"/></svg>`

    const releaseApiUrl = "https://api.github.com/repos/vFactor-io/vfactor-desktop/releases/latest"
    const fallbackReleaseUrl = "https://github.com/vFactor-io/vfactor-desktop/releases/latest"
    const cardIcons = {
      'mac-arm64': apple,
      'mac-x64': apple,
      'windows-x64': windows,
    }

    if (/Mac|iPhone|iPad|iPod/.test(ua)) {
      icon.innerHTML = apple
      label.textContent = 'Download for Mac'
    } else if (/Win/.test(ua)) {
      icon.innerHTML = windows
      label.textContent = 'Download for Windows'
    } else if (/Linux/.test(ua)) {
      icon.innerHTML = linux
      label.textContent = 'Download for Linux'
    } else {
      icon.innerHTML = apple
      label.textContent = 'Download'
    }

    downloadCards.forEach((card) => {
      const iconSlot = card.querySelector<HTMLElement>('[data-download-card-icon]')
      const platform = card.dataset.platform as keyof typeof cardIcons | undefined
      if (iconSlot && platform) {
        iconSlot.innerHTML = cardIcons[platform]
      }
    })

    const resolvePreferredPlatform = () => {
      if (/Mac|iPhone|iPad|iPod/.test(ua)) return 'mac-arm64'
      if (/Win/.test(ua)) return 'windows-x64'
      return 'mac-arm64'
    }

    const assetPatterns = {
      'mac-arm64': /vFactor-.+-arm64\.dmg$/i,
      'mac-x64': /vFactor-.+-x64\.dmg$/i,
      'windows-x64': /vFactor-.+-x64\.exe$/i,
    }

    async function hydrateDownloadLinks() {
      try {
        const response = await fetch(releaseApiUrl, {
          headers: { Accept: 'application/vnd.github+json' },
        })
        if (!response.ok) return

        const release = await response.json()
        const assets = Array.isArray(release.assets) ? release.assets : []
        const links = Object.fromEntries(
          Object.entries(assetPatterns).map(([platform, pattern]) => {
            const asset = assets.find((candidate: { name?: string }) =>
              typeof candidate.name === 'string' && pattern.test(candidate.name)
            )
            return [platform, asset?.browser_download_url ?? fallbackReleaseUrl]
          })
        )

        downloadCards.forEach((card) => {
          const platform = card.dataset.platform
          if (platform && typeof links[platform] === 'string') {
            card.href = links[platform]
          }
        })

        const preferredLink = links[resolvePreferredPlatform()] ?? fallbackReleaseUrl
        primaryDownloadLinks.forEach((link) => {
          link.href = preferredLink
        })
      } catch {
        primaryDownloadLinks.forEach((link) => {
          link.href = fallbackReleaseUrl
        })
      }
    }

    void hydrateDownloadLinks()

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible')
        }
      })
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' })

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el))
  </script>

  <style>
    .hidden-sm {
      display: none;
    }
    @media (min-width: 640px) {
      .hidden-sm {
        display: inline-flex;
      }
    }

    .terminal-line {
      opacity: 0;
      animation: fadeIn 0.3s ease forwards;
    }

    .terminal-line:nth-child(1) { animation-delay: 0.2s; }
    .terminal-line:nth-child(2) { animation-delay: 0.6s; }
    .terminal-line:nth-child(3) { animation-delay: 1.0s; }
    .terminal-line:nth-child(4) { animation-delay: 1.3s; }
    .terminal-line:nth-child(5) { animation-delay: 1.6s; }
    .terminal-line:nth-child(6) { animation-delay: 1.9s; }
    .terminal-line:nth-child(7) { animation-delay: 2.2s; }
    .terminal-line:nth-child(8) { animation-delay: 2.5s; }
    .terminal-line:nth-child(9) { animation-delay: 2.8s; }
    .terminal-line:nth-child(10) { animation-delay: 3.1s; }
    .terminal-line:nth-child(11) { animation-delay: 3.4s; }
    .terminal-line:nth-child(12) { animation-delay: 3.7s; }
    .terminal-line:nth-child(13) { animation-delay: 4.0s; }
    .terminal-line:nth-child(14) { animation-delay: 4.3s; }
    .terminal-line:nth-child(15) { animation-delay: 4.6s; }
  </style>
</BaseLayout>
