{
  "name": "vfactor-desktop",
  "version": "0.1.22",
  "description": "Desktop ADE for local-first coding projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/vFactor-io/vfactor-desktop.git"
  },
  "type": "module",
  "main": "out/main/main.js",
  "private": true,
  "scripts": {
    "dev": "bun run prepare:icons dev && electron-vite dev",
    "preview": "electron-vite preview",
    "build": "bun run prepare:icons prod && electron-vite build",
    "prepare:icons": "bun run ../../scripts/prepare-desktop-icons.ts",
    "prepare:runtime-env": "bun run ../../scripts/write-desktop-runtime-env.ts",
    "dist": "bun run build && bun run prepare:runtime-env && electron-builder",
    "dist:local": "bun run build && bun run prepare:runtime-env && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir --mac -c.mac.identity=-",
    "release": "bun run build && bun run prepare:runtime-env && electron-builder --publish onTag",
    "cli": "bun run index.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "bun run ../../scripts/install-desktop-app-deps.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "37.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "typescript": "^5",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "@base-ui/react": "^1.0.0",
    "@headless-tree/core": "^1.6.2",
    "@headless-tree/react": "^1.6.2",
    "@lexical/react": "^0.41.0",
    "@monaco-editor/react": "^4.7.0",
    "@opencode-ai/sdk": "^1.1.11",
    "@phosphor-icons/react": "^2.1.10",
    "@pierre/diffs": "^1.1.15",
    "@pierre/trees": "^1.0.0-beta.3",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-symbols/icons": "^1.3.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-virtual": "^3.13.23",
    "@wterm/dom": "^0.1.9",
    "ai": "^6.0.23",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.35.0",
    "lexical": "^0.41.0",
    "nanoid": "^5.1.6",
    "node-pty": "^1.0.0",
    "posthog-node": "^5.28.11",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shadcn": "^3.6.3",
    "streamdown": "^1.6.11",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.1",
    "zustand": "^5.0.9"
  },
  "build": {
    "appId": "io.vfactor.desktop",
    "productName": "vFactor",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "../../release"
    },
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "icon.png",
          "dock.png",
          "icon.icns",
          "icon.ico",
          "128x128.png",
          "32x32.png"
        ]
      },
      {
        "from": "build/runtime",
        "to": ".",
        "filter": [
          ".env"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "vFactor-io",
        "repo": "vfactor-desktop"
      }
    ],
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": ["nsis"],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
